# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/

# Build artifacts
build/
dist/
*.egg
uv.lock

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ---- Data dirs: track code + index files, ignore user content ----

# memory/: track code (*.py, __init__.py) but NOT the memory markdown files
memory/**/*.md
!memory/README.md
memory/user/
memory/feedback/
memory/project/
memory/general/

# knowledge/: track code, don't track user's knowledge notes
knowledge/*/
!knowledge/**/__init__.py
knowledge/**/*.md
!knowledge/README.md

# Voice / Reminders / Docs / Dream — personal-only feature folders
voice/
reminders/
docs/
dream/

# Legacy / backup files from the restructure
*.old
*.bak

# Personal config / state — never commit
Persona.md
.codex
.claude/
.serena_local/
*.local.json
*.local.toml
config.local.*

# Reminders runtime data (DB lives in user's home, but ignore stray inputs/outputs)
reminders/inputs/*
reminders/outputs/*
!reminders/inputs/.gitkeep
!reminders/outputs/.gitkeep

# Dream consolidations (runtime memory snapshots)
dream/*.json
dream/*.md
dream/*.log
