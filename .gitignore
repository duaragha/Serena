# ---- Data dirs: track code + index files, ignore user content ----

# memory/: track code (*.py, __init__.py) but NOT the memory markdown files
memory/**/*.md
!memory/README.md
memory/user/
memory/feedback/
memory/project/
memory/general/

# knowledge/: track code, don't track user's knowledge notes
knowledge/*/
!knowledge/**/__init__.py
knowledge/**/*.md
!knowledge/README.md

# Voice: heavy models and runtime state
voice/models/
voice/__pycache__/

# Legacy / backup files from the restructure
*.old
